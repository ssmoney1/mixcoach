# Copy this file to .env and fill in your keys.

# Google Gemini API key (required).
GEMINI_API_KEY=

# ROEX_API_KEY= (disabled, uncomment to re-enable)
# All RoEx Tonn API integration is currently disabled. Local pyloudnorm +
# librosa analysis runs unconditionally. Re-enable by uncommenting the
# `# ROEX_DISABLED` blocks in python/capture_and_analyze.py and src/main/*.

# Override which Python interpreter the Electron main process uses to launch
# the sidecar scripts. Defaults to "python" on Windows, "python3" elsewhere.
# Useful if you keep dependencies in a venv:
# MIXCOACH_PYTHON=C:\Users\your7\Documents\mixcoach\python\.venv\Scripts\python.exe

# Override where the FLP parser searches for projects. Defaults to
# ~/Documents/Image-Line/FL Studio/Projects. Set this if FL Studio's User Data
# Folder is configured to a custom location.
# MIXCOACH_FLP_DIR=C:\FLUserData\FL Studio\Projects
